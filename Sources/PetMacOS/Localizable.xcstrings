    "Claude Code wasn't found on this Mac (%@ or the claude command). Claude Code is the command-line tool running in Terminal that Desktop Pet watches — it needs to be installed before connecting.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Claude Code wasn't found on this Mac (%@ or the claude command). Claude Code is the command-line tool running in Terminal that Desktop Pet watches — it needs to be installed before connecting."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chưa tìm thấy Claude Code trên máy này (%@ hoặc lệnh claude). Claude Code là công cụ dòng lệnh chạy trong Terminal mà Desktop Pet theo dõi — cần cài nó trước khi kết nối."
          }
        }
      }
    },

          }
        }
      }
    },
    "Desktop Pet is a desktop dog that reflects what Claude Code is doing — thinking, running a tool, waiting on a permission decision, or just finished. Connecting only takes about a minute.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Desktop Pet is a desktop dog that reflects what Claude Code is doing — thinking, running a tool, waiting on a permission decision, or just finished. Connecting only takes about a minute."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Desktop Pet là một chú chó để bàn phản ánh trạng thái làm việc của Claude Code — đang suy nghĩ, đang chạy tool, đang chờ bạn quyết định quyền, hay vừa xong việc. Chỉ mất khoảng 1 phút để kết nối."
          }
        }
      }
    },
    "The app is running from a temporary location (not yet in /Applications)": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The app is running from a temporary location (not yet in /Applications)"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "App đang chạy từ nơi tạm (chưa ở /Applications)"
          }
        }
      }
    },
    "Drag Desktop Pet into the Applications folder before connecting, so the install and hook aren't lost when you eject the DMG or restart your Mac.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag Desktop Pet into the Applications folder before connecting, so the install and hook aren't lost when you eject the DMG or restart your Mac."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nên kéo Desktop Pet vào thư mục Applications trước khi kết nối, để cài đặt và hook không bị mất khi bạn đóng ổ đĩa DMG hoặc khởi động lại máy."
          }
        }
      }
    },
    "Checking for Claude Code": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Checking for Claude Code"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kiểm tra Claude Code"
          }
        }
